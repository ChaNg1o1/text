{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "text",
  "version": "0.1.0",
  "identifier": "com.text.forensics",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build && node ../scripts/release/run_python.js ../scripts/release/build_api_sidecar.py",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; media-src 'self' blob:",
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/text-api/*",
      "bin/text-api/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "copyright": "Copyright 2024-2026 text contributors",
    "shortDescription": "Multi-agent forensic text analysis platform",
    "longDescription": "Text forensics desktop client with multi-agent collaboration for authorship attribution, profiling, and sockpuppet detection.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
